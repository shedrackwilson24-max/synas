rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn(); }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Phase 4: Entity Validations
    function isValidUser(data) {
      return data.name is string && data.name.size() > 0 &&
             (!data.keys().hasAny(['email']) || data.email is string) &&
             (!data.keys().hasAny(['photoURL']) || (data.photoURL is string || data.photoURL == null)) &&
             (!data.keys().hasAny(['lastLoginAt']) || data.lastLoginAt is timestamp) &&
             (!data.keys().hasAny(['createdAt']) || data.createdAt is timestamp) &&
             (!data.keys().hasAny(['updatedAt']) || 
               (request.method == 'create' && data.updatedAt == request.time) || 
               (request.method == 'update' && (data.updatedAt == request.time || data.updatedAt == existing().updatedAt))
             ) &&
             (!data.keys().hasAny(['setup_complete']) || data.setup_complete is bool) &&
             (!data.keys().hasAny(['age']) || data.age is number) &&
             (!data.keys().hasAny(['weight']) || data.weight is number) &&
             (!data.keys().hasAny(['height']) || data.height is number) &&
             (!data.keys().hasAny(['gender']) || data.gender is string) &&
             (!data.keys().hasAny(['goal']) || data.goal is string) &&
             (!data.keys().hasAny(['activity_level']) || data.activity_level is string) &&
             (!data.keys().hasAny(['frequency']) || data.frequency is number) &&
             (!data.keys().hasAny(['focus_areas']) || data.focus_areas is list) &&
             (!data.keys().hasAny(['activity_rank']) || data.activity_rank is number) &&
             (!data.keys().hasAny(['goalCalories']) || data.goalCalories is number) &&
             (!data.keys().hasAny(['walletAddress']) || (data.walletAddress is string || data.walletAddress == null)) &&
             (!data.keys().hasAny(['walletType']) || (data.walletType is string || data.walletType == null)) &&
             (!data.keys().hasAny(['discordId']) || (data.discordId is string && data.discordId.size() <= 100)) &&
             (!data.keys().hasAny(['units']) || data.units is string) &&
             (!data.keys().hasAny(['privacy_public']) || data.privacy_public is bool) &&
             (!data.keys().hasAny(['privacy_sync']) || data.privacy_sync is bool) &&
             (!data.keys().hasAny(['notifications_push']) || data.notifications_push is bool) &&
             (!data.keys().hasAny(['notifications_email']) || data.notifications_email is bool) &&
             (!data.keys().hasAny(['reown_project_id']) || data.reown_project_id is string);
    }

    function isValidWorkout(data) {
      return data.userId == request.auth.uid &&
             data.duration is number &&
             data.name is string &&
             data.calories is number &&
             data.exercises is list;
    }

    function isValidWorkoutPlan(data) {
      return data.keys().hasAll(['userId', 'generated_at', 'week_schedule']) &&
             data.userId == request.auth.uid &&
             data.generated_at == request.time &&
             data.week_schedule is list;
    }

    function isValidDailyStats(data) {
      return data.userId == request.auth.uid &&
             data.date is string &&
             (!data.keys().hasAny(['calories']) || data.calories is number) &&
             (!data.keys().hasAny(['goalCalories']) || data.goalCalories is number) &&
             (!data.keys().hasAny(['steps']) || data.steps is number) &&
             (!data.keys().hasAny(['distance']) || data.distance is number) &&
             (!data.keys().hasAny(['appleHealthSynced']) || data.appleHealthSynced is bool) &&
             (!data.keys().hasAny(['garminSynced']) || data.garminSynced is bool);
    }

    function isValidIntegrationState(data) {
      return (!data.keys().hasAny(['googleFit']) || data.googleFit is bool) &&
             (!data.keys().hasAny(['appleHealth']) || data.appleHealth is bool) &&
             (!data.keys().hasAny(['garmin']) || data.garmin is bool);
    }

    function isValidSleepData(data) {
      return data.userId == request.auth.uid &&
             data.date is string &&
             data.hours is number;
    }

    function isValidBodyData(data) {
      return data.userId == request.auth.uid &&
             data.date is string &&
             data.weight is number;
    }

    function isValidReadinessData(data) {
      return data.userId == request.auth.uid &&
             data.date is string &&
             data.score is number;
    }

    function isValidPB(data) {
      return data.keys().hasAll(['userId', 'maxCalories', 'maxSteps', 'maxDistance']) &&
             data.userId == request.auth.uid &&
             data.maxCalories is number &&
             data.maxSteps is number &&
             data.maxDistance is number &&
             (!data.keys().hasAny(['totalWorkouts']) || data.totalWorkouts is number);
    }

    function isValidHabit(data) {
      return data.userId == request.auth.uid &&
             data.name is string && data.name.size() <= 100 &&
             data.value is string && data.value.size() <= 100;
    }

    function isValidRecommendation(data) {
      return data.userId == request.auth.uid &&
             data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 1000;
    }

    function isValidWaitlist(data) {
      return data.email is string && data.email.size() > 0 &&
             data.timestamp == request.time &&
             (!data.keys().hasAny(['source']) || data.source is string);
    }

    function isValidFeedback(data) {
      return data.userEmail is string &&
             data.timestamp == request.time &&
             (!data.keys().hasAny(['rating']) || data.rating is number) &&
             (!data.keys().hasAny(['devices']) || data.devices is string) &&
             (!data.keys().hasAny(['desiredFeatures']) || data.desiredFeatures is string);
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'shedrackwilson24@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // Action helpers for Users
    function isWalletUpdate() {
      return incoming().diff(existing()).affectedKeys().hasOnly(['walletAddress', 'walletType', 'updatedAt']);
    }
    
    function isProfileUpdate() {
      return incoming().diff(existing()).affectedKeys().hasOnly([
          'name', 'email', 'photoURL', 'age', 'weight', 'height', 'gender', 
          'goal', 'activity_level', 'frequency', 'focus_areas', 'activity_rank', 
          'discordId', 'setup_complete', 'updatedAt', 'goalCalories', 'createdAt',
          'units', 'privacy_public', 'privacy_sync', 'notifications_push', 
          'notifications_email', 'reown_project_id'
      ]);
    }

    function isLastLoginUpdate() {
        return incoming().diff(existing()).affectedKeys().hasOnly(['lastLoginAt']);
    }

    // 1. Users Collection
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isValidUser(incoming()) && (
          (isOwner(userId) && (isWalletUpdate() || isProfileUpdate() || isLastLoginUpdate())) ||
          isAdmin()
      );
    }

    // 2. Workout Plans Collection
    match /workoutPlans/{planUserId} {
      allow get: if isSignedIn() && (request.auth.uid == planUserId || (resource != null && resource.data.userId == request.auth.uid) || isAdmin());
      allow list: if isAdmin();
      allow create, update: if isSignedIn() && planUserId == request.auth.uid && incoming().userId == request.auth.uid && isValidWorkoutPlan(incoming());
    }

    // 3. Workouts History Collection
    match /workouts/{workoutId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // 4. Daily Stats Collection
    match /dailyStats/{statId} {
      allow get: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidDailyStats(incoming());
      allow update: if isSignedIn() && (resource != null && resource.data.userId == request.auth.uid) && isValidDailyStats(incoming());
    }

    // 5. Personal Bests Collection
    match /personalBests/{pbUserId} {
      allow get: if isSignedIn() && (request.auth.uid == pbUserId || (resource != null && resource.data.userId == request.auth.uid));
      allow create: if isSignedIn() && pbUserId == request.auth.uid && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && pbUserId == request.auth.uid && incoming().userId == request.auth.uid;
    }

    // 6. OTPs Collection (Deprecated)
    match /otps/{otpId} {
      allow read, write: if false;
    }

    // 7. Habits Collection
    match /habits/{habitId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidHabit(incoming());
      allow update: if isSignedIn() && incoming().userId == request.auth.uid && isValidHabit(incoming());
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // 8. Recommendations Collection
    match /recommendations/{recId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidRecommendation(incoming());
    }

    // 9. Sleep Data Collection
    match /sleep_data/{logId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create, update: if isSignedIn() && incoming().userId == request.auth.uid && isValidSleepData(incoming());
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // 10. Body Data Collection
    match /body_data/{logId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create, update: if isSignedIn() && incoming().userId == request.auth.uid && isValidBodyData(incoming());
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // 11. Readiness Data Collection
    match /readiness_data/{readinessId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create, update: if isSignedIn() && (incoming() == null || incoming().userId == request.auth.uid) && isValidReadinessData(incoming());
    }

    // 12. Waitlist Collection
    match /waitlist/{entryId} {
      allow create: if isValidWaitlist(incoming());
      allow get, list: if isAdmin();
    }

    // 13. Feedback Collection
    match /feedback/{feedbackId} {
      allow create: if isSignedIn() && isValidFeedback(incoming());
      allow get, list: if isAdmin();
    }

    // 14. User Integrations
    match /user_integrations/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && isValidIntegrationState(incoming());
    }
  }
}
